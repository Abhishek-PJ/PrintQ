# Copy this file to .env and fill in your values

# Address of your PrintQ server (no trailing slash)
SERVER_URL=https://your-printq-server.com

# Secret key provided by your PrintQ administrator
AGENT_SECRET=

# Your shop ID provided by your PrintQ administrator
SHOP_ID=

# Printer name exactly as shown by: wmic printer get name
PRINTER_NAME=

# Full path to SumatraPDF.exe if not in the default location
# SUMATRA_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe

# Full path to LibreOffice soffice executable (needed for .docx/.doc files)
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
